# Скопируйте в .env на VPS (никогда не коммитьте реальный .env в git!)

# Путь к приватному RSA-ключу (сгенерирован через gen_keys.py на локальной машине,
# скопирован на VPS вручную по SCP/SFTP — НЕ через git).
PIXIE_PRIVATE_KEY_PATH=/opt/pixie/private_key.pem

# Путь к SQLite базе лицензий (создастся автоматически при первом запуске).
PIXIE_LICENSE_DB=/opt/pixie/licenses.db

# Токен для защиты /license/generate и /license/revoke (придумайте длинную случайную строку).
PIXIE_ADMIN_TOKEN=change-me-to-a-long-random-string

# Разрешённые CORS-источники для сайта (через запятую). Используйте "*" только для теста.
PIXIE_CORS_ORIGINS=https://pixie-ai.pro,https://www.pixie-ai.pro

# Секрет для проверки подписи вебхука Lava.top (см. личный кабинет Lava.top -> настройки магазина).
# Оставьте пустым до подключения Lava.top.
LAVA_WEBHOOK_SECRET=

# Секрет IPN для NowPayments (личный кабинет NowPayments -> Store settings -> IPN secret).
# Оставьте пустым до подключения NowPayments.
NOWPAYMENTS_IPN_SECRET=

# --- SMTP Яндекс (дублирующая отправка ключа на email, основной канал — сайт) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=pixie.ai.delivery@ya.ru
SMTP_PASSWORD=change-me-app-password
SMTP_FROM_EMAIL=pixie.ai.delivery@ya.ru
