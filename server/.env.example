# =============================================================================
# Pixie License Server — Environment Configuration
# =============================================================================
# Скопируйте этот файл в .env и заполните секреты.
# ВАЖНО: .env НИКОГДА не должен попадать в git (уже в .gitignore).
# =============================================================================

# --- Приватный RSA-ключ для подписи лицензий ---
# Сгенерируйте через: python agent/gen_keys.py
# Затем скопируйте private_key.pem на сервер и укажите путь:
PRIVATE_KEY_PATH=./private_key.pem

# --- База данных (SQLite для простоты, PostgreSQL для прода) ---
DATABASE_URL=sqlite:///./pixie_licenses.db

# --- SMTP (Яндекс Почта для отправки ключей) ---
# Используется для отправки лицензионного ключа на email покупателя
# и для восстановления ключа через форму "Lost your key?"
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=pixie.ai.delivery@ya.ru
SMTP_PASSWORD=your_yandex_app_password_here
SMTP_FROM=pixie.ai.delivery@ya.ru
SMTP_FROM_NAME=Pixie Pro License

# --- Платежные провайдеры (Webhook секреты для верификации) ---
# Lava.top: секрет для проверки подписи webhook'а
LAVA_WEBHOOK_SECRET=your_lava_webhook_secret_here
# NowPayments: API-ключ для проверки подписи
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret_here

# --- Безопасность ---
# Секретный ключ для подписи JWT сессий (если используется)
SECRET_KEY=generate-random-string-here
# Разрешённые origins для CORS
CORS_ORIGINS=https://pixie-ai.pro,https://www.pixie-ai.pro

# --- Сервер ---
HOST=0.0.0.0
PORT=8000