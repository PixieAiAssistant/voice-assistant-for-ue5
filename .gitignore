node_modules
__pycache__
.venv
.env
.env.*
!.env.example

# Pixie licensing: приватный ключ НИКОГДА не должен попадать в git/exe.
private_key.pem
pixie_license_state.json
config.json

# Персональный конфиг путей движка/проекта (у каждого разработчика свой) —
# не коммитим, чтобы не тащить в репозиторий чужие локальные пути к дискам.
agent/pixie_config.json

# Pixie license server (VPS): БД лицензий и ключи — не коммитить.
agent/server/*.pem
agent/server/*.db
agent/server/.env

# ВНИМАНИЕ: эти скрипты содержат реальный root-пароль VPS в открытом виде —
# НИКОГДА не коммитить. Если нужно поделиться логикой деплоя — используйте
# только *.example версии без секретов.
deploy/deploy.py
deploy/deploy_site.py


# Артефакты сборки Nuitka / Inno Setup — генерируются CI или локально,
# в репозиторий не кладём (большие бинарники, легко пересобрать).
agent/dist/
agent/build/
agent/*.build/
agent/*.dist/
agent/*.onefile-build/
installer/output/

# Runtime-артефакты приложения (создаются при запуске, не нужны в git).
agent/pixie_agent.log
agent/script_library_index.json
agent/ue_temp_scripts/
*.log
